# Spark Pulse API — Environment Variables
# Copy to .env and fill in values

# SparkDB (MySQL — read-only, reconciled transaction data)
SPARKDB_HOST=spark.giselato.com
SPARKDB_PORT=3306
SPARKDB_NAME=SparkDB
SPARKDB_USER=spark_reader
SPARKDB_PASSWORD=

# MongoDB (Astro — pre-aggregated daily data)
MONGODB_URI=mongodb+srv://...
MONGODB_DB=astro

# NocoDB (reference master data)
NOCODB_HOST=giselato.com
NOCODB_PORT=3306
NOCODB_NAME=sparkdb_nocodb
NOCODB_USER=nocodb_user
NOCODB_PASSWORD=

# App
SPARK_PULSE_ENV=dev
SPARK_PULSE_PORT=8100
CORS_ORIGINS=http://localhost:3000,http://mini
